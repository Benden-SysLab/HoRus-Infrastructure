# Ansible
*.retry
*.log

# Secrets and Keys
# Ignore everything in these directories...
/bootstrap/ssh/*
/bootstrap/certs/*
/bootstrap/secrets_plain.txt
# ...except these specific management files
!/bootstrap/ssh/README.md
!/bootstrap/ssh/.gitignore
!/bootstrap/ssh/generate_ssh_keys.sh
!/bootstrap/certs/README.md
!/bootstrap/certs/.gitignore

# Inventory Secrets
/inventory/group_vars/vault_inventory.yml

# OS / IDE
.DS_Store
.vscode/
.idea/
.history/

# Deployment Reports
results/
/runtime/

# Node/Vite (if any residue)
node_modules/
dist/
.env
